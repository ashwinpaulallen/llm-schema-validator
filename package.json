{
  "name": "llm-schema-validator",
  "version": "1.3.0",
  "description": "Structured LLM outputs with a TypeScript field schema: parse, coerce, validate, and retry. OpenAI, Anthropic, Gemini, Ollama, and custom providers.",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.3.0"
  },
  "browser": "./dist/index.js",
  "packageManager": "npm@10",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.esm.json && tsc -p tsconfig.build.cjs.json && node scripts/write-cjs-package-json.mjs",
    "prepublishOnly": "npm run build",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "llm",
    "ai",
    "json",
    "validation",
    "openai",
    "anthropic",
    "structured output",
    "schema"
  ],
  "author": "Ashwin Paul Allen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashwinpaulallen/llm-schema-validator.git"
  },
  "bugs": {
    "url": "https://github.com/ashwinpaulallen/llm-schema-validator/issues"
  },
  "homepage": "https://github.com/ashwinpaulallen/llm-schema-validator#readme",
  "funding": "https://github.com/sponsors/ashwinpaulallen",
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.80.0",
    "openai": ">=4.0.0",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@eslint/js": "^10.0.1",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "openai": "^6.34.0",
    "prettier": "^3.8.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4",
    "zod": "^3.25.76"
  }
}
