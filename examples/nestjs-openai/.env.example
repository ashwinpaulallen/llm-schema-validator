# Chat Completions base URL (include /v1). Official API: https://api.openai.com/v1 — or a compatible server.
OPENAI_BASE_URL=http://127.0.0.1:1234/v1

OPENAI_MODEL=replace-with-your-model-id

# Real key for api.openai.com; many compatible servers accept any non-empty string
OPENAI_API_KEY=sk-local

PORT=3000
